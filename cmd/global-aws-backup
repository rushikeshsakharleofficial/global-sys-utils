#!/usr/bin/env python3
"""Backup aged log files to AWS S3."""

from __future__ import annotations

import argparse
import fnmatch
import hashlib
import logging
import os
import random
import re
import socket
import sys
import time
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Any

import boto3
from boto3.s3.transfer import TransferConfig
from botocore.exceptions import BotoCoreError, ClientError

# Single-threaded S3 transfers: boto3 default spawns up to 10 threads per file,
# each buffering an 8 MB chunk — brutal on small machines.
_S3_TRANSFER_CONFIG = TransferConfig(
    max_concurrency=1,
    multipart_threshold=50 * 1024 * 1024,  # only multipart for files > 50 MB
    multipart_chunksize=8 * 1024 * 1024,
)

logger = logging.getLogger(__name__)

_DATE_RE = re.compile(r'\d{4}-\d{2}-\d{2}|\d{8}')


def _extract_date(name: str) -> datetime | None:
    m = _DATE_RE.search(name)
    if not m:
        return None
    s = m.group()
    for fmt in ('%Y%m%d', '%Y-%m-%d'):
        try:
            return datetime.strptime(s, fmt).replace(tzinfo=timezone.utc)
        except ValueError:
            pass
    return None


def _parse_s3_url(url: str) -> tuple[str, str]:
    if not url.startswith('s3://'):
        sys.exit(f"ERROR: invalid S3 URL {url!r}: must start with s3://")
    bucket, _, prefix = url[5:].partition('/')
    return bucket, prefix.rstrip('/')


def _object_key(path: str, prefix: str, hostname: str) -> str:
    p = Path(path)
    rel = str(p.parent).lstrip('/')
    parts = [part for part in (prefix, hostname, rel, p.name) if part]
    return '/'.join(parts)


def _md5(path: str) -> str:
    h = hashlib.md5()
    with open(path, 'rb') as f:
        for chunk in iter(lambda: f.read(65536), b''):
            h.update(chunk)
    return h.hexdigest()


def _upload(s3: Any, path: str, bucket: str, key: str, verify: bool, retries: int) -> None:
    local_md5 = _md5(path) if verify else None
    last_err: Exception | None = None
    for attempt in range(1, retries + 1):
        if attempt > 1:
            delay = min(2 ** (attempt - 2) + random.uniform(0, 0.5), 30)
            time.sleep(delay)
        try:
            s3.upload_file(path, bucket, key, Config=_S3_TRANSFER_CONFIG)
            if verify:
                etag = s3.head_object(Bucket=bucket, Key=key)['ETag'].strip('"')
                if '-' not in etag and etag != local_md5:
                    raise ValueError(f"checksum mismatch: local={local_md5} s3={etag}")
            return
        except (BotoCoreError, ClientError, ValueError) as e:
            last_err = e
            logger.debug("upload attempt %d/%d failed for %s: %s", attempt, retries, key, e)
    raise RuntimeError(f"upload s3://{bucket}/{key} failed after {retries} attempt(s): {last_err}")


def main() -> None:
    ap = argparse.ArgumentParser(
        prog='global-aws-backup',
        description='Backup log files to AWS S3.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  global-aws-backup --source /var/log/apps --destination s3://my-bucket/logs --days 30\n"
            "  global-aws-backup --source /var/log/apps --destination s3://my-bucket/logs --days 30 \\\n"
            "      --pattern '*.gz' --parallel 8 --dry-run"
        ),
    )
    ap.add_argument('--source',      required=True,                    help='Source directory to scan')
    ap.add_argument('--destination', required=True,                    help='S3 destination (s3://bucket[/prefix])')
    ap.add_argument('--days',        required=True, type=int,          help='Process files dated older than N days')
    ap.add_argument('--pattern',     default='*',                      help='Filename glob to include (default: *)')
    ap.add_argument('--exclude',     action='append', default=[],      help='Filename glob to exclude; repeatable', metavar='GLOB')
    ap.add_argument('--parallel',    type=int, default=4,              help='Concurrent uploads (default: 4)')
    ap.add_argument('--profile',     default=None,                     help='AWS profile name')
    ap.add_argument('--region',      default=None,                     help='AWS region')
    ap.add_argument('--retries',     type=int, default=3,              help='Upload retry count (default: 3)')
    ap.add_argument('--copy',        action='store_true',              help='Copy files instead of moving (preserve source)')
    ap.add_argument('--no-verify',   action='store_true', dest='no_verify', help='Skip MD5 verification after upload')
    ap.add_argument('--dry-run',     action='store_true', dest='dry_run',   help='Print actions without making changes')
    ap.add_argument('--verbose',     action='store_true',              help='Enable debug logging')
    args = ap.parse_args()

    logging.basicConfig(format='%(message)s', level=logging.DEBUG if args.verbose else logging.INFO)

    bucket, prefix = _parse_s3_url(args.destination)
    hostname = socket.gethostname()
    cutoff = (
        datetime.now(tz=timezone.utc)
        .replace(hour=0, minute=0, second=0, microsecond=0)
        - timedelta(days=args.days)
    )

    candidates: list[str] = []
    for root, _, files in os.walk(args.source):
        for name in files:
            if not fnmatch.fnmatch(name, args.pattern):
                continue
            path = os.path.join(root, name)
            if any(fnmatch.fnmatch(name, ex) or fnmatch.fnmatch(path, ex) for ex in args.exclude):
                continue
            t = _extract_date(name)
            if t is None or t >= cutoff:
                continue
            candidates.append(path)

    if not candidates:
        logger.info("No files matching criteria found in %s", args.source)
        sys.exit(0)

    action = 'copy' if args.copy else 'move'
    logger.info("Found %d file(s) to %s (cutoff: %s)", len(candidates), action, cutoff.strftime('%Y-%m-%d'))

    if args.dry_run:
        for path in candidates:
            key = _object_key(path, prefix, hostname)
            logger.info("[DRY-RUN] Would %s: %s -> s3://%s/%s", action, path, bucket, key)
        logger.info("\nTotal: %d file(s)", len(candidates))
        return

    session = boto3.Session(profile_name=args.profile, region_name=args.region)
    s3 = session.client('s3')

    def process(path: str) -> bool:
        key = _object_key(path, prefix, hostname)
        try:
            _upload(s3, path, bucket, key, verify=not args.no_verify, retries=args.retries)
        except Exception as e:
            logger.error("%s: %s", path, e)
            return False
        verb = 'Copied' if args.copy else 'Moved'
        if not args.copy:
            os.remove(path)
        logger.info("%s: %s -> s3://%s/%s", verb, path, bucket, key)
        return True

    with ThreadPoolExecutor(max_workers=args.parallel) as pool:
        results = list(pool.map(process, candidates))

    ok, fail = results.count(True), results.count(False)
    logger.info("\nDone: %d succeeded, %d failed", ok, fail)
    if fail:
        sys.exit(1)


if __name__ == '__main__':
    main()
