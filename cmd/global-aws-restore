#!/usr/bin/env python3
"""Restore log files from AWS S3."""

from __future__ import annotations

import argparse
import fnmatch
import logging
import os
import random
import sys
import threading
import time
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path
from typing import Any

import boto3
from boto3.s3.transfer import TransferConfig
from botocore.exceptions import BotoCoreError, ClientError

logger = logging.getLogger(__name__)

_S3_TRANSFER_CONFIG = TransferConfig(
    max_concurrency=1,
    multipart_threshold=50 * 1024 * 1024,
    multipart_chunksize=8 * 1024 * 1024,
)


class AdaptiveThrottle:
    """Dynamically caps concurrent workers based on live CPU and memory usage."""

    _MEM_HIGH = 80
    _MEM_LOW  = 55
    _CPU_HIGH = 85
    _CPU_LOW  = 60
    _POLL_SEC = 3

    def __init__(self, min_workers: int = 1, max_workers: int = 1) -> None:
        try:
            import psutil as _p
            self._psutil = _p
        except ImportError:
            self._psutil = None
            logger.warning("psutil not installed — adaptive throttling disabled. pip install psutil")

        self.min_workers = max(1, min_workers)
        self.max_workers = max(self.min_workers, max_workers)

        if self._psutil:
            avail_mb = self._psutil.virtual_memory().available // (1024 * 1024)
            initial = max(self.min_workers, min(self.max_workers, avail_mb // 100))
        else:
            initial = self.max_workers

        self._target = initial
        self._active = 0
        self._cond   = threading.Condition(threading.Lock())
        self._stop   = threading.Event()

        if self._psutil:
            t = threading.Thread(target=self._monitor, daemon=True, name="throttle-mon")
            t.start()
            logger.debug("adaptive throttle: initial=%d  min=%d  max=%d", initial, self.min_workers, self.max_workers)

    def __enter__(self) -> AdaptiveThrottle:
        with self._cond:
            while self._active >= self._target:
                self._cond.wait(timeout=1.0)
            self._active += 1
        return self

    def __exit__(self, *_: object) -> None:
        with self._cond:
            self._active -= 1
            self._cond.notify_all()

    def stop(self) -> None:
        self._stop.set()

    def _monitor(self) -> None:
        psutil = self._psutil
        while not self._stop.wait(self._POLL_SEC):
            cpu = psutil.cpu_percent(interval=0.5)
            mem = psutil.virtual_memory().percent
            with self._cond:
                old = self._target
                if mem > self._MEM_HIGH or cpu > self._CPU_HIGH:
                    self._target = max(self.min_workers, self._target - 1)
                elif mem < self._MEM_LOW and cpu < self._CPU_LOW:
                    self._target = min(self.max_workers, self._target + 1)
                if self._target != old:
                    logger.info(
                        "throttle: %d→%d workers  cpu=%.0f%%  mem=%.0f%%",
                        old, self._target, cpu, mem,
                    )
                    self._cond.notify_all()


def _parse_s3_url(url: str) -> tuple[str, str]:
    if not url.startswith('s3://'):
        sys.exit(f"ERROR: invalid S3 URL {url!r}: must start with s3://")
    bucket, _, prefix = url[5:].partition('/')
    return bucket, prefix.rstrip('/')


def _local_path(key: str, prefix: str, dest: str, flatten: bool) -> str:
    if flatten:
        return str(Path(dest) / Path(key).name)
    return str(Path(dest) / key.removeprefix(prefix).lstrip('/'))


def _download(s3: Any, bucket: str, key: str, dest_path: str, retries: int) -> None:
    last_err: Exception | None = None
    for attempt in range(1, retries + 1):
        if attempt > 1:
            delay = min(2 ** (attempt - 2) + random.uniform(0, 0.5), 30)
            time.sleep(delay)
        try:
            Path(dest_path).parent.mkdir(parents=True, exist_ok=True)
            s3.download_file(bucket, key, dest_path, Config=_S3_TRANSFER_CONFIG)
            return
        except (BotoCoreError, ClientError) as e:
            if os.path.exists(dest_path):
                os.remove(dest_path)
            last_err = e
            logger.debug("download attempt %d/%d failed for %s: %s", attempt, retries, key, e)
    raise RuntimeError(f"download s3://{bucket}/{key} failed after {retries} attempt(s): {last_err}")


def main() -> None:
    ap = argparse.ArgumentParser(
        prog='global-aws-restore',
        description='Restore log files from AWS S3.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  global-aws-restore --source s3://my-bucket/logs --destination /var/log/restore\n"
            "  global-aws-restore --source s3://my-bucket/logs/myhost --destination /tmp/restore \\\n"
            "      --pattern '*.gz' --parallel 8 --flatten --dry-run"
        ),
    )
    ap.add_argument('--source',      required=True,               help='S3 source (s3://bucket[/prefix])')
    ap.add_argument('--destination', required=True,               help='Local directory to restore into')
    ap.add_argument('--pattern',     default='*',                 help='Filename glob to include (default: *)')
    ap.add_argument('--exclude',     action='append', default=[], help='Filename glob to exclude; repeatable', metavar='GLOB')
    ap.add_argument('--parallel',    type=int, default=4,         help='Max concurrent downloads; adaptive throttle may use fewer (default: 4)')
    ap.add_argument('--profile',     default=None,                help='AWS profile name')
    ap.add_argument('--region',      default=None,                help='AWS region')
    ap.add_argument('--retries',     type=int, default=3,         help='Download retry count (default: 3)')
    ap.add_argument('--flatten',     action='store_true',         help='Put all files directly in destination (no subdirs)')
    ap.add_argument('--dry-run',     action='store_true', dest='dry_run', help='Print actions without downloading anything')
    ap.add_argument('--verbose',     action='store_true',         help='Enable debug logging')
    args = ap.parse_args()

    logging.basicConfig(format='%(message)s', level=logging.DEBUG if args.verbose else logging.INFO)

    bucket, prefix = _parse_s3_url(args.source)

    session = boto3.Session(profile_name=args.profile, region_name=args.region)
    s3 = session.client('s3')

    list_prefix = (prefix + '/') if prefix else ''
    logger.info("Listing objects under s3://%s/%s ...", bucket, prefix)

    paginator = s3.get_paginator('list_objects_v2')
    objects: list[str] = []
    for page in paginator.paginate(Bucket=bucket, Prefix=list_prefix):
        for obj in page.get('Contents', []):
            objects.append(obj['Key'])

    candidates: list[str] = []
    for key in objects:
        name = Path(key).name
        if not fnmatch.fnmatch(name, args.pattern):
            continue
        if any(fnmatch.fnmatch(name, ex) or fnmatch.fnmatch(key, ex) for ex in args.exclude):
            continue
        candidates.append(key)

    if not candidates:
        logger.info("No objects found matching criteria.")
        sys.exit(0)
    logger.info("Found %d object(s) to restore", len(candidates))

    if args.dry_run:
        for key in candidates:
            dest = _local_path(key, prefix, args.destination, args.flatten)
            logger.info("[DRY-RUN] Would download: s3://%s/%s -> %s", bucket, key, dest)
        logger.info("\nTotal: %d object(s)", len(candidates))
        return

    os.makedirs(args.destination, exist_ok=True)

    throttle = AdaptiveThrottle(min_workers=1, max_workers=args.parallel)

    def process(key: str) -> bool:
        dest = _local_path(key, prefix, args.destination, args.flatten)
        if os.path.exists(dest):
            logger.info("Skipping (exists): %s", dest)
            return True
        try:
            _download(s3, bucket, key, dest, retries=args.retries)
        except Exception as e:
            logger.error("%s: %s", key, e)
            return False
        logger.info("Restored: s3://%s/%s -> %s", bucket, key, dest)
        return True

    def _run(key: str) -> bool:
        with throttle:
            return process(key)

    try:
        with ThreadPoolExecutor(max_workers=args.parallel) as pool:
            results = list(pool.map(_run, candidates))
    finally:
        throttle.stop()

    ok, fail = results.count(True), results.count(False)
    logger.info("\nDone: %d succeeded, %d failed", ok, fail)
    if fail:
        sys.exit(1)


if __name__ == '__main__':
    main()
