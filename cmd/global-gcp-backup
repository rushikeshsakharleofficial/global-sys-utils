#!/usr/bin/env python3
"""Backup aged log files to Google Cloud Storage."""

from __future__ import annotations

import argparse
import fnmatch
import logging
import os
import random
import re
import socket
import sys
import threading
import time
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Any

from google.api_core.exceptions import GoogleAPIError
from google.cloud import storage

logger = logging.getLogger(__name__)

_DATE_RE = re.compile(r'\d{4}-\d{2}-\d{2}|\d{8}')


class AdaptiveThrottle:
    """Dynamically caps concurrent workers based on live CPU and memory usage."""

    _MEM_HIGH = 80
    _MEM_LOW  = 55
    _CPU_HIGH = 85
    _CPU_LOW  = 60
    _POLL_SEC = 3

    def __init__(self, min_workers: int = 1, max_workers: int = 1) -> None:
        try:
            import psutil as _p
            self._psutil = _p
        except ImportError:
            self._psutil = None
            logger.warning("psutil not installed — adaptive throttling disabled. pip install psutil")

        self.min_workers = max(1, min_workers)
        self.max_workers = max(self.min_workers, max_workers)

        if self._psutil:
            avail_mb = self._psutil.virtual_memory().available // (1024 * 1024)
            initial = max(self.min_workers, min(self.max_workers, avail_mb // 100))
        else:
            initial = self.max_workers

        self._target = initial
        self._active = 0
        self._cond   = threading.Condition(threading.Lock())
        self._stop   = threading.Event()

        if self._psutil:
            t = threading.Thread(target=self._monitor, daemon=True, name="throttle-mon")
            t.start()
            logger.debug("adaptive throttle: initial=%d  min=%d  max=%d", initial, self.min_workers, self.max_workers)

    def __enter__(self) -> AdaptiveThrottle:
        with self._cond:
            while self._active >= self._target:
                self._cond.wait(timeout=1.0)
            self._active += 1
        return self

    def __exit__(self, *_: object) -> None:
        with self._cond:
            self._active -= 1
            self._cond.notify_all()

    def stop(self) -> None:
        self._stop.set()

    def _monitor(self) -> None:
        psutil = self._psutil
        while not self._stop.wait(self._POLL_SEC):
            cpu = psutil.cpu_percent(interval=0.5)
            mem = psutil.virtual_memory().percent
            with self._cond:
                old = self._target
                if mem > self._MEM_HIGH or cpu > self._CPU_HIGH:
                    self._target = max(self.min_workers, self._target - 1)
                elif mem < self._MEM_LOW and cpu < self._CPU_LOW:
                    self._target = min(self.max_workers, self._target + 1)
                if self._target != old:
                    logger.info(
                        "throttle: %d→%d workers  cpu=%.0f%%  mem=%.0f%%",
                        old, self._target, cpu, mem,
                    )
                    self._cond.notify_all()


def _extract_date(name: str) -> datetime | None:
    m = _DATE_RE.search(name)
    if not m:
        return None
    s = m.group()
    for fmt in ('%Y%m%d', '%Y-%m-%d'):
        try:
            return datetime.strptime(s, fmt).replace(tzinfo=timezone.utc)
        except ValueError:
            pass
    return None


def _parse_gcs_url(url: str) -> tuple[str, str]:
    if not url.startswith('gs://'):
        sys.exit(f"ERROR: invalid GCS URL {url!r}: must start with gs://")
    bucket, _, prefix = url[5:].partition('/')
    return bucket, prefix.rstrip('/')


def _object_path(path: str, prefix: str, hostname: str) -> str:
    p = Path(path)
    rel = str(p.parent).lstrip('/')
    parts = [part for part in (prefix, hostname, rel, p.name) if part]
    return '/'.join(parts)


def _upload(client: Any, path: str, bucket_name: str, blob_name: str, verify: bool, retries: int) -> None:
    last_err: Exception | None = None
    for attempt in range(1, retries + 1):
        if attempt > 1:
            delay = min(2 ** (attempt - 2) + random.uniform(0, 0.5), 30)
            time.sleep(delay)
        try:
            bucket = client.bucket(bucket_name)
            blob = bucket.blob(blob_name)
            # chunk_size forces resumable upload for files larger than one chunk,
            # keeping only 8 MB in memory at a time instead of the whole file.
            blob.chunk_size = 8 * 1024 * 1024
            blob.upload_from_filename(path, checksum='md5' if verify else None)
            return
        except (GoogleAPIError, Exception) as e:
            last_err = e
            logger.debug("upload attempt %d/%d failed for %s: %s", attempt, retries, blob_name, e)
    raise RuntimeError(f"upload gs://{bucket_name}/{blob_name} failed after {retries} attempt(s): {last_err}")


def main() -> None:
    ap = argparse.ArgumentParser(
        prog='global-gcp-backup',
        description='Backup log files to Google Cloud Storage.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  global-gcp-backup --source /var/log/apps --destination gs://my-bucket/logs --days 30\n"
            "  global-gcp-backup --source /var/log/apps --destination gs://my-bucket/logs --days 30 \\\n"
            "      --pattern '*.gz' --parallel 8 --dry-run"
        ),
    )
    ap.add_argument('--source',      required=True,                    help='Source directory to scan')
    ap.add_argument('--destination', required=True,                    help='GCS destination (gs://bucket[/prefix])')
    ap.add_argument('--days',        required=True, type=int,          help='Process files dated older than N days')
    ap.add_argument('--pattern',     default='*',                      help='Filename glob to include (default: *)')
    ap.add_argument('--exclude',     action='append', default=[],      help='Filename glob to exclude; repeatable', metavar='GLOB')
    ap.add_argument('--parallel',    type=int, default=4,              help='Max concurrent uploads; adaptive throttle may use fewer (default: 4)')
    ap.add_argument('--project',     default=None,                     help='GCP project ID')
    ap.add_argument('--credentials', default=None,                     help='Path to service account JSON key file')
    ap.add_argument('--retries',     type=int, default=3,              help='Upload retry count (default: 3)')
    ap.add_argument('--copy',        action='store_true',              help='Copy files instead of moving (preserve source)')
    ap.add_argument('--no-verify',   action='store_true', dest='no_verify', help='Skip MD5 verification after upload')
    ap.add_argument('--dry-run',     action='store_true', dest='dry_run',   help='Print actions without making changes')
    ap.add_argument('--verbose',     action='store_true',              help='Enable debug logging')
    args = ap.parse_args()

    logging.basicConfig(format='%(message)s', level=logging.DEBUG if args.verbose else logging.INFO)

    bucket_name, prefix = _parse_gcs_url(args.destination)
    hostname = socket.gethostname()
    cutoff = (
        datetime.now(tz=timezone.utc)
        .replace(hour=0, minute=0, second=0, microsecond=0)
        - timedelta(days=args.days)
    )

    candidates: list[str] = []
    for root, _, files in os.walk(args.source):
        for name in files:
            if not fnmatch.fnmatch(name, args.pattern):
                continue
            path = os.path.join(root, name)
            if any(fnmatch.fnmatch(name, ex) or fnmatch.fnmatch(path, ex) for ex in args.exclude):
                continue
            t = _extract_date(name)
            if t is None or t >= cutoff:
                continue
            candidates.append(path)

    if not candidates:
        logger.info("No files matching criteria found in %s", args.source)
        sys.exit(0)

    action = 'copy' if args.copy else 'move'
    logger.info("Found %d file(s) to %s (cutoff: %s)", len(candidates), action, cutoff.strftime('%Y-%m-%d'))

    if args.dry_run:
        for path in candidates:
            blob_name = _object_path(path, prefix, hostname)
            logger.info("[DRY-RUN] Would %s: %s -> gs://%s/%s", action, path, bucket_name, blob_name)
        logger.info("\nTotal: %d file(s)", len(candidates))
        return

    client_kwargs: dict[str, Any] = {}
    if args.project:
        client_kwargs['project'] = args.project
    if args.credentials:
        from google.oauth2 import service_account
        client_kwargs['credentials'] = service_account.Credentials.from_service_account_file(args.credentials)
    client = storage.Client(**client_kwargs)

    throttle = AdaptiveThrottle(min_workers=1, max_workers=args.parallel)

    def process(path: str) -> bool:
        blob_name = _object_path(path, prefix, hostname)
        try:
            _upload(client, path, bucket_name, blob_name, verify=not args.no_verify, retries=args.retries)
        except Exception as e:
            logger.error("%s: %s", path, e)
            return False
        verb = 'Copied' if args.copy else 'Moved'
        if not args.copy:
            os.remove(path)
        logger.info("%s: %s -> gs://%s/%s", verb, path, bucket_name, blob_name)
        return True

    def _run(path: str) -> bool:
        with throttle:
            return process(path)

    try:
        with ThreadPoolExecutor(max_workers=args.parallel) as pool:
            results = list(pool.map(_run, candidates))
    finally:
        throttle.stop()

    ok, fail = results.count(True), results.count(False)
    logger.info("\nDone: %d succeeded, %d failed", ok, fail)
    if fail:
        sys.exit(1)


if __name__ == '__main__':
    main()
