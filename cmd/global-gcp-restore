#!/usr/bin/env python3
"""Restore log files from Google Cloud Storage."""

from __future__ import annotations

import argparse
import fnmatch
import logging
import os
import random
import sys
import threading
import time
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path
from typing import Any

from google.api_core.exceptions import GoogleAPIError
from google.cloud import storage

logger = logging.getLogger(__name__)


class AdaptiveThrottle:
    """Dynamically caps concurrent workers based on live CPU and memory usage."""

    _MEM_HIGH = 80
    _MEM_LOW  = 55
    _CPU_HIGH = 85
    _CPU_LOW  = 60
    _POLL_SEC = 3

    def __init__(self, min_workers: int = 1, max_workers: int = 1) -> None:
        try:
            import psutil as _p
            self._psutil = _p
        except ImportError:
            self._psutil = None
            logger.warning("psutil not installed — adaptive throttling disabled. pip install psutil")

        self.min_workers = max(1, min_workers)
        self.max_workers = max(self.min_workers, max_workers)

        if self._psutil:
            avail_mb = self._psutil.virtual_memory().available // (1024 * 1024)
            initial = max(self.min_workers, min(self.max_workers, avail_mb // 100))
        else:
            initial = self.max_workers

        self._target = initial
        self._active = 0
        self._cond   = threading.Condition(threading.Lock())
        self._stop   = threading.Event()

        if self._psutil:
            t = threading.Thread(target=self._monitor, daemon=True, name="throttle-mon")
            t.start()
            logger.debug("adaptive throttle: initial=%d  min=%d  max=%d", initial, self.min_workers, self.max_workers)

    def __enter__(self) -> AdaptiveThrottle:
        with self._cond:
            while self._active >= self._target:
                self._cond.wait(timeout=1.0)
            self._active += 1
        return self

    def __exit__(self, *_: object) -> None:
        with self._cond:
            self._active -= 1
            self._cond.notify_all()

    def stop(self) -> None:
        self._stop.set()

    def _monitor(self) -> None:
        psutil = self._psutil
        while not self._stop.wait(self._POLL_SEC):
            cpu = psutil.cpu_percent(interval=0.5)
            mem = psutil.virtual_memory().percent
            with self._cond:
                old = self._target
                if mem > self._MEM_HIGH or cpu > self._CPU_HIGH:
                    self._target = max(self.min_workers, self._target - 1)
                elif mem < self._MEM_LOW and cpu < self._CPU_LOW:
                    self._target = min(self.max_workers, self._target + 1)
                if self._target != old:
                    logger.info(
                        "throttle: %d→%d workers  cpu=%.0f%%  mem=%.0f%%",
                        old, self._target, cpu, mem,
                    )
                    self._cond.notify_all()


def _parse_gcs_url(url: str) -> tuple[str, str]:
    if not url.startswith('gs://'):
        sys.exit(f"ERROR: invalid GCS URL {url!r}: must start with gs://")
    bucket, _, prefix = url[5:].partition('/')
    return bucket, prefix.rstrip('/')


def _local_path(blob_name: str, prefix: str, dest: str, flatten: bool) -> str:
    if flatten:
        return str(Path(dest) / Path(blob_name).name)
    return str(Path(dest) / blob_name.removeprefix(prefix).lstrip('/'))


def _download(client: Any, bucket_name: str, blob_name: str, dest_path: str, retries: int) -> None:
    last_err: Exception | None = None
    for attempt in range(1, retries + 1):
        if attempt > 1:
            delay = min(2 ** (attempt - 2) + random.uniform(0, 0.5), 30)
            time.sleep(delay)
        try:
            Path(dest_path).parent.mkdir(parents=True, exist_ok=True)
            blob = client.bucket(bucket_name).blob(blob_name)
            blob.chunk_size = 8 * 1024 * 1024
            blob.download_to_filename(dest_path)
            return
        except (GoogleAPIError, Exception) as e:
            if os.path.exists(dest_path):
                os.remove(dest_path)
            last_err = e
            logger.debug("download attempt %d/%d failed for %s: %s", attempt, retries, blob_name, e)
    raise RuntimeError(f"download gs://{bucket_name}/{blob_name} failed after {retries} attempt(s): {last_err}")


def main() -> None:
    ap = argparse.ArgumentParser(
        prog='global-gcp-restore',
        description='Restore log files from Google Cloud Storage.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  global-gcp-restore --source gs://my-bucket/logs --destination /var/log/restore\n"
            "  global-gcp-restore --source gs://my-bucket/logs/myhost --destination /tmp/restore \\\n"
            "      --pattern '*.gz' --flatten --dry-run"
        ),
    )
    ap.add_argument('--source',      required=True,               help='GCS source (gs://bucket[/prefix])')
    ap.add_argument('--destination', required=True,               help='Local directory to restore into')
    ap.add_argument('--pattern',     default='*',                 help='Filename glob to include (default: *)')
    ap.add_argument('--exclude',     action='append', default=[], help='Filename glob to exclude; repeatable', metavar='GLOB')
    ap.add_argument('--parallel',    type=int, default=4,         help='Max concurrent downloads; adaptive throttle may use fewer (default: 4)')
    ap.add_argument('--project',     default=None,                help='GCP project ID')
    ap.add_argument('--credentials', default=None,                help='Path to service account JSON key file')
    ap.add_argument('--retries',     type=int, default=3,         help='Download retry count (default: 3)')
    ap.add_argument('--flatten',     action='store_true',         help='Put all files directly in destination (no subdirs)')
    ap.add_argument('--dry-run',     action='store_true', dest='dry_run', help='Print actions without downloading anything')
    ap.add_argument('--verbose',     action='store_true',         help='Enable debug logging')
    args = ap.parse_args()

    logging.basicConfig(format='%(message)s', level=logging.DEBUG if args.verbose else logging.INFO)

    bucket_name, prefix = _parse_gcs_url(args.source)

    client_kwargs: dict[str, Any] = {}
    if args.project:
        client_kwargs['project'] = args.project
    if args.credentials:
        from google.oauth2 import service_account
        client_kwargs['credentials'] = service_account.Credentials.from_service_account_file(args.credentials)
    client = storage.Client(**client_kwargs)

    list_prefix = (prefix + '/') if prefix else ''
    logger.info("Listing blobs under gs://%s/%s ...", bucket_name, prefix)

    blobs: list[str] = [b.name for b in client.list_blobs(bucket_name, prefix=list_prefix)]

    candidates: list[str] = []
    for name in blobs:
        base = Path(name).name
        if not fnmatch.fnmatch(base, args.pattern):
            continue
        if any(fnmatch.fnmatch(base, ex) or fnmatch.fnmatch(name, ex) for ex in args.exclude):
            continue
        candidates.append(name)

    if not candidates:
        logger.info("No blobs found matching criteria.")
        sys.exit(0)
    logger.info("Found %d blob(s) to restore", len(candidates))

    if args.dry_run:
        for name in candidates:
            dest = _local_path(name, prefix, args.destination, args.flatten)
            logger.info("[DRY-RUN] Would download: gs://%s/%s -> %s", bucket_name, name, dest)
        logger.info("\nTotal: %d blob(s)", len(candidates))
        return

    os.makedirs(args.destination, exist_ok=True)

    throttle = AdaptiveThrottle(min_workers=1, max_workers=args.parallel)

    def process(blob_name: str) -> bool:
        dest = _local_path(blob_name, prefix, args.destination, args.flatten)
        if os.path.exists(dest):
            logger.info("Skipping (exists): %s", dest)
            return True
        try:
            _download(client, bucket_name, blob_name, dest, retries=args.retries)
        except Exception as e:
            logger.error("%s: %s", blob_name, e)
            return False
        logger.info("Restored: gs://%s/%s -> %s", bucket_name, blob_name, dest)
        return True

    def _run(blob_name: str) -> bool:
        with throttle:
            return process(blob_name)

    try:
        with ThreadPoolExecutor(max_workers=args.parallel) as pool:
            results = list(pool.map(_run, candidates))
    finally:
        throttle.stop()

    ok, fail = results.count(True), results.count(False)
    logger.info("\nDone: %d succeeded, %d failed", ok, fail)
    if fail:
        sys.exit(1)


if __name__ == '__main__':
    main()
